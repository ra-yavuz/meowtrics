#!/bin/sh
# postrm for meowtrics
set -e

# Stop and disable the meowtrics user service for every user that has it
# enabled. Mirrors the auto-enable path in postinst.
disable_for_user() {
    user="$1"
    home=$(getent passwd "$user" | cut -d: -f6)
    [ -n "$home" ] && [ -d "$home" ] || return 0

    uid=$(id -u "$user" 2>/dev/null || echo "")
    if [ -n "$uid" ] && [ -d "/run/user/$uid" ]; then
        sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" \
            systemctl --user stop meowtrics.service 2>/dev/null || true
    fi
    rm -f "$home/.config/systemd/user/graphical-session.target.wants/meowtrics.service" 2>/dev/null || true
    if [ -n "$uid" ] && [ -d "/run/user/$uid" ]; then
        sudo -u "$user" XDG_RUNTIME_DIR="/run/user/$uid" \
            systemctl --user daemon-reload 2>/dev/null || true
    fi
}

cleanup_user_state() {
    home="$1"
    [ -d "$home" ] || return 0
    rm -rf -- "$home/.config/meowtrics" "$home/.cache/meowtrics" 2>/dev/null || true
}

case "$1" in
    purge)
        for user in $(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 {print $1}'); do
            disable_for_user "$user"
            home=$(getent passwd "$user" | cut -d: -f6)
            cleanup_user_state "$home"
        done
        cleanup_user_state /root

        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        if [ -x /usr/bin/gtk-update-icon-cache ]; then
            /usr/bin/gtk-update-icon-cache -q -t /usr/share/icons/hicolor 2>/dev/null || true
        fi
        if command -v kbuildsycoca6 >/dev/null 2>&1; then
            kbuildsycoca6 --noincremental >/dev/null 2>&1 || true
        fi
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # On plain `remove` (not purge), tear down the user enables so the
        # service stops trying to start, but leave per-user config + cache
        # alone so a reinstall picks up where we left off.
        for user in $(getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 {print $1}'); do
            disable_for_user "$user"
        done
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload >/dev/null 2>&1 || true
        fi
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#
exit 0
